# opentop 環境變數範本
# 1. 複製成 .env: cp .env.example .env
# 2. 填入真實的 key
# 3. .env 已加入 .gitignore, 不會被 commit
#
# 設定 LLM API key (給 OpenCode Zen)
OPENCODE_ZEN_API_KEY=sk-your-key-here

# 如使用其他 provider, 設對應的 env 變數 (config.yml 內的 api_key_env 要對應)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
